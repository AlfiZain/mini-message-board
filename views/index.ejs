<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
</head>
<body>
    <header>
        <%- include("navbar", {links: links}) %>
    </header>
    <main>
        <% messages.forEach((message) => { %>
            <div style="border: 1px solid black; margin-bottom: 1rem; padding: 1rem;">
                <p><%= message.user%></p>
                <p><%= message.text%></p>
                <p><%= message.added%></p>
                <a href="/messages/<%= message.user %>">See Detail</a>
            </div>
        <%}); %>
    </main>
</body>
</html>